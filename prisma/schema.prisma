generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  address   String
  quantity  String
  time      String
  status    String   @default("Trial")
  createdAt DateTime @default(now())
}
model Order {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  address   String
  product   String
  quantity  String
  payment   String   @default("COD")
  status    String   @default("Pending")
  deliveryCharge Float @default(0)
  createdAt DateTime @default(now())
}
model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float
  unit      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
model Customer {
  id                String    @id @default(cuid())
  name              String
  mobile            String    @unique
  address           String
  trialStart        DateTime?
  trialEnd          DateTime?
  subscription      Boolean   @default(false)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  createdAt         DateTime  @default(now())
}
