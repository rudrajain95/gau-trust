generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  address   String
  quantity  String
  time      String
  status    String   @default("Trial")
  createdAt DateTime @default(now())
}

model Order {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  mobile        String
  address       String
  latitude      Float?
  longitude     Float?
  product       String
  quantity      String
  payment       String   @default("COD")
  status        String   @default("Pending")
  deliveryCharge Float   @default(0)
  createdAt     DateTime @default(now())

  shop          Shop     @relation(fields:[shopId], references:[id])
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float
  unit      String
  shopId    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
}

model Customer {
  id                String    @id @default(cuid())
  name              String
  mobile            String    @unique
  address           String
  trialStart        DateTime?
  trialEnd          DateTime?
  subscription      Boolean   @default(false)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  coins             Int       @default(0)
  createdAt         DateTime  @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  mobile    String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  ownerName String?
  mobile    String   @unique
  address   String
  area      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  address   String
  latitude  Float?
  longitude Float?
  mobile    String
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  products  Product[]
  orders    Order[]
}
