generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  address   String
  quantity  String
  time      String
  status    String   @default("Trial")
  createdAt DateTime @default(now())
}
model Order {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  address   String
  product   String
  quantity  String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}
